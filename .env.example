# API
LOG_LEVEL=INFO
MAX_UPLOAD_BYTES=15728640
# TESTING=true desativa conexão Mongo no lifespan (uso em pytest)
TESTING=false

# MongoDB (docker-compose define MONGODB_URL para o serviço api)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=nfe_processor

# LLM: openai (predefinido) ou gemini
LLM_PROVIDER=openai

# OpenAI ou endpoint compatível (Chat Completions)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (Google AI Studio) — usado se LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# PDF cache (entradas LRU em memória)
PDF_CACHE_MAX_ENTRIES=256

# Registrar metadados em processed_invoices
STORE_PROCESSED_METADATA=true

# POST /extract-pdf (só PDF, para testes — desligado por defeito)
ENABLE_PDF_EXTRACT_ENDPOINT=false
